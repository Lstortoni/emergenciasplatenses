@page "/"
@inject IEmergenciasApiClient ApiClient

<PageTitle>Emergencias Platenses</PageTitle>

<section class="home-header">
    <span class="home-eyebrow">Servicios de emergencia</span>
    <h1>¿Qué necesitás hoy?</h1>
    <p>Encontrá ayuda confiable en La Plata en pocos segundos.</p>

    <div class="search-preview" aria-label="La búsqueda se habilitará próximamente">
        <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-4-4" />
        </svg>
        <span>Buscar servicios...</span>
        <small>Próximamente</small>
    </div>
</section>

<section>
    <div class="section-title">
        <h2>Categorías</h2>
        <span>@_categorias.Count disponibles</span>
    </div>

    @if (_cargando)
    {
        <div class="status-card">Cargando categorías...</div>
    }
    else if (_mensajeError is not null)
    {
        <div class="status-card error">
            <strong>No pudimos conectar con la API.</strong>
            <span>@_mensajeError</span>
            <button @onclick="CargarCategoriasAsync">Reintentar</button>
        </div>
    }
    else if (_categorias.Count == 0)
    {
        <div class="status-card">No hay categorías disponibles.</div>
    }
    else
    {
        <div class="category-grid">
            @foreach (var categoria in _categorias)
            {
                <a class="category-card" href="@($"/comercios/{categoria.Id}")">
                    <div class="category-icon">
                        <CategoriaIcon Nombre="@categoria.Icono" Descripcion="@categoria.Nombre" />
                    </div>
                    <strong>@categoria.Nombre</strong>
                    <small>Ver servicios</small>
                </a>
            }
        </div>
    }
</section>

@code {
    private IReadOnlyCollection<Categoria> _categorias = [];
    private bool _cargando = true;
    private string? _mensajeError;

    protected override async Task OnInitializedAsync()
    {
        await CargarCategoriasAsync();
    }

    private async Task CargarCategoriasAsync()
    {
        _cargando = true;
        _mensajeError = null;

        try
        {
            _categorias = await ApiClient.ObtenerCategoriasAsync();
        }
        catch (HttpRequestException)
        {
            _mensajeError = "Verificá que la API esté ejecutándose en http://localhost:5112.";
        }
        catch (TaskCanceledException)
        {
            _mensajeError = "La API tardó demasiado en responder.";
        }
        finally
        {
            _cargando = false;
        }
    }
}
